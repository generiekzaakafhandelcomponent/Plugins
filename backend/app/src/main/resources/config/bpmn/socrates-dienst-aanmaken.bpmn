      <bpmn:script>// common functions
function toJavaValue(value) {
    if (value == null) return null;

    var valueType = typeof value;

    if (valueType === 'string') return String(value);
    if (valueType === 'number') return Number(value);
    if (valueType === 'boolean') return value;

    if (Array.isArray(value)) {
        return toJavaList(value);
    }

    if (valueType === 'object') {
        return toJavaMap(value);
    }

    return String(value);
}

function toJavaMap(obj) {
    var map = new Packages.java.util.LinkedHashMap();

    for (var key in obj) {
        if (Object.prototype.hasOwnProperty.call(obj, key)) {
            map.put(String(key), toJavaValue(obj[key]));
        }
    }

    return map;
}

function toJavaList(arr) {
    var list = new Packages.java.util.ArrayList();

    for (var i = 0; i &lt; arr.length; i++) {
        list.add(toJavaValue(arr[i]));
    }

    return list;
}

var loBehandeld = {
