      <bpmn:outgoing>Flow_1d5hfs8</bpmn:outgoing>
      <bpmn:multiInstanceLoopCharacteristics isSequential="true" camunda:asyncBefore="true" camunda:collection="kadasterAanduidingen" camunda:elementVariable="kadasterAanduiding" />
    </bpmn:serviceTask>
    <bpmn:scriptTask id="Activity_0sfjmnj" name="Initieer KadasterObjecten" scriptFormat="javascript">
      <bpmn:incoming>Flow_1eprbn3</bpmn:incoming>
      <bpmn:outgoing>Flow_1fqz1uv</bpmn:outgoing>
      <bpmn:script>const ArrayList = Java.type("java.util.ArrayList");
var kadasterObjecten = new ArrayList();
execution.setVariable('kadasterObjecten', kadasterObjecten);

var kadasterAanduidingen = execution.getVariable('kadasterAanduidingenObject').dynamicProperties

execution.setVariable('kadasterAanduidingen', kadasterAanduidingen);
</bpmn:script>
    </bpmn:scriptTask>
