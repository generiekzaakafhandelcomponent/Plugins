    <bpmn:serviceTask id="MultiInstance_Activity_Ophalen_KadasterObjecten" name="Suwinet: Ophalen KadasterObjecten" camunda:expression="${true}">
      <bpmn:extensionElements>
        <camunda:executionListener event="end">
          <camunda:script scriptFormat="javascript">var kadasterObject = execution.getVariable('kadasterObject');

print(kadasterObject);

var kadasterObjectList = execution.getVariable('kadasterObjecten');

kadasterObjectList.push(kadasterObject);</camunda:script>
        </camunda:executionListener>
      </bpmn:extensionElements>
